{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[[...route]]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/[[...route]].ts": {
      "memory": 1024,
      "maxDuration": 30
    }
  }
}
