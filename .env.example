# Server
PORT=5000

# Local workspace root
# Default behavior uses the parent directory of this repo.
# Set this explicitly on a new computer if your source folders live elsewhere.
LOCAL_WORKSPACE_ROOT=/Users/your-name/Desktop/Code

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=exaone3.5:latest

# Supabase
# Fill these if you want explicit, portable local config or Vercel deployment.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key
